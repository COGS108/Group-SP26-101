## YOUR CODE TO LOAD/CLEAN/TIDY/WRANGLE THE DATA GOES HERE
import pandas as pd
import numpy as np

file_path = 'data/00-raw/bls_national_2023.xlsx'
raw_bls_df = pd.read_excel(file_path)

cols_to_keep = ['OCC_CODE', 'OCC_TITLE', 'O_GROUP', 'TOT_EMP', 'A_MEDIAN', 'A_MEAN']
bls_df = raw_bls_df[cols_to_keep].copy()

print(f"Original dataset size: {bls_df.shape[0]} rows and {bls_df.shape[1]} columns.")
display(bls_df.head())





bls_tidy = bls_df[bls_df['O_GROUP'] == 'detailed'].copy()
bls_tidy = bls_tidy.drop(columns=['O_GROUP'])

print(f"Tidy dataset size (only detailed occupations): {bls_tidy.shape[0]} rows.")





print("Count of suppressed/missing values (represented by '*' or '#'):")
for col in ['TOT_EMP', 'A_MEDIAN', 'A_MEAN']:
    star_count = bls_tidy[col].astype(str).str.contains(r'\*').sum()
    hash_count = bls_tidy[col].astype(str).str.contains(r'\#').sum()
    print(f"{col} - '*' count: {star_count}, '#' count: {hash_count}")





pd.set_option('future.no_silent_downcasting', True)
bls_tidy.replace(['*', '#', '**'], np.nan, inplace=True)

for col in ['TOT_EMP', 'A_MEDIAN', 'A_MEAN']:
    bls_tidy[col] = bls_tidy[col].astype(str).str.replace(',', '', regex=False)
    bls_tidy[col] = pd.to_numeric(bls_tidy[col], errors='coerce')

bls_clean = bls_tidy.dropna(how='any')

print(f"Final cleaned dataset size: {bls_clean.shape}")





display(bls_clean.describe())

print("\nTop 3 occupations with highest employment:")
display(bls_clean.nlargest(3, 'TOT_EMP'))





aioe_raw = pd.read_excel(
    "data/00-raw/Language Modeling AIOE and AIIE.xlsx",
    sheet_name="LM AIOE"
)

print("Dataset shape:", aioe_raw.shape)
print("Columns:", aioe_raw.columns.tolist())

aioe_raw.head()


aioe_clean = aioe_raw[[
    "SOC Code",
    "Occupation Title",
    "Language Modeling AIOE"
]].copy()

aioe_clean = aioe_clean.rename(columns={
    "SOC Code": "soc_code",
    "Occupation Title": "occupation_title",
    "Language Modeling AIOE": "aioe_score"
})

aioe_clean.head()


aioe_clean["soc_code"] = aioe_clean["soc_code"].astype(str).str.strip()
aioe_clean["occupation_title"] = aioe_clean["occupation_title"].astype(str).str.strip()
aioe_clean["aioe_score"] = pd.to_numeric(aioe_clean["aioe_score"], errors="coerce")

aioe_clean.dtypes


print("Missing values:")
display(aioe_clean.isna().sum())

print("Duplicated rows:", aioe_clean.duplicated().sum())
print("Duplicated SOC codes:", aioe_clean["soc_code"].duplicated().sum())


aioe_clean = aioe_clean.dropna(subset=["soc_code", "occupation_title", "aioe_score"])
aioe_clean = aioe_clean.drop_duplicates()

print("Cleaned dataset shape:", aioe_clean.shape)

print("Missing values after cleaning:")
display(aioe_clean.isna().sum())

print("Duplicated rows after cleaning:", aioe_clean.duplicated().sum())
print("Duplicated SOC codes after cleaning:", aioe_clean["soc_code"].duplicated().sum())


median_aioe = aioe_clean["aioe_score"].median()

aioe_clean["ai_exposure_group"] = np.where(
    aioe_clean["aioe_score"] > median_aioe,
    "above_median",
    "below_median"
)

print("Median AIOE score:", median_aioe)
aioe_clean["ai_exposure_group"].value_counts()





bls_clean.loc[:, "OCC_CODE"] = bls_clean["OCC_CODE"].astype(str).str.strip()

merged_df = pd.merge(
    bls_clean,
    aioe_clean,
    left_on="OCC_CODE",
    right_on="soc_code",
    how="inner"
)

print(f"Merge successful. Combined dataset contains {len(merged_df)} rows.")

merged_df[[
    "OCC_CODE",
    "OCC_TITLE",
    "TOT_EMP",
    "A_MEDIAN",
    "aioe_score",
    "ai_exposure_group"
]].head()


print("Missing values in merged dataset:")
display(merged_df[[
    "OCC_CODE",
    "OCC_TITLE",
    "TOT_EMP",
    "A_MEDIAN",
    "aioe_score",
    "ai_exposure_group"
]].isna().sum())

print("Duplicated rows in merged dataset:", merged_df.duplicated().sum())





# Save and reload the current cleaned merged dataset for EDA
# This follows the checkpoint instruction to use a processed dataset for analysis

import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

os.makedirs("data/02-processed", exist_ok=True)

processed_path = "data/02-processed/merged_2023_bls_aioe.csv"
merged_df.to_csv(processed_path, index=False)

eda_df = pd.read_csv(processed_path)

for col in ["TOT_EMP", "A_MEDIAN", "A_MEAN", "aioe_score"]:
    eda_df[col] = pd.to_numeric(eda_df[col], errors="coerce")

eda_df = eda_df.dropna(subset=["TOT_EMP", "A_MEDIAN", "aioe_score", "ai_exposure_group"])

print("EDA dataset shape:", eda_df.shape)
display(eda_df[["OCC_CODE", "OCC_TITLE", "TOT_EMP", "A_MEDIAN", "aioe_score", "ai_exposure_group"]].head())





plt.figure(figsize=(8, 5))
plt.hist(eda_df["aioe_score"], bins=30)
plt.xlabel("AIOE Score")
plt.ylabel("Number of Occupations")
plt.title("Distribution of AI Exposure Scores")
plt.show()

display(eda_df["ai_exposure_group"].value_counts())








plt.figure(figsize=(8, 5))
plt.hist(eda_df["A_MEDIAN"], bins=30)
plt.xlabel("2023 Median Annual Wage")
plt.ylabel("Number of Occupations")
plt.title("Distribution of 2023 Median Annual Wage")
plt.show()

eda_df["log_tot_emp"] = np.log10(eda_df["TOT_EMP"])

plt.figure(figsize=(8, 5))
plt.hist(eda_df["log_tot_emp"], bins=30)
plt.xlabel("Log10 Total Employment")
plt.ylabel("Number of Occupations")
plt.title("Distribution of 2023 Employment Size")
plt.show()


print("Top 10 occupations by median annual wage:")
display(
    eda_df.sort_values("A_MEDIAN", ascending=False)[
        ["OCC_TITLE", "A_MEDIAN", "TOT_EMP", "aioe_score", "ai_exposure_group"]
    ].head(10)
)

print("Top 10 occupations by total employment:")
display(
    eda_df.sort_values("TOT_EMP", ascending=False)[
        ["OCC_TITLE", "A_MEDIAN", "TOT_EMP", "aioe_score", "ai_exposure_group"]
    ].head(10)
)








group_summary = eda_df.groupby("ai_exposure_group")[["A_MEDIAN", "TOT_EMP", "aioe_score"]].agg(["count", "mean", "median"])
display(group_summary)

plt.figure(figsize=(8, 5))
eda_df.boxplot(column="A_MEDIAN", by="ai_exposure_group")
plt.title("2023 Median Annual Wage by AI Exposure Group")
plt.suptitle("")
plt.xlabel("AI Exposure Group")
plt.ylabel("Median Annual Wage")
plt.show()








plt.figure(figsize=(8, 5))
plt.scatter(eda_df["aioe_score"], eda_df["A_MEDIAN"], alpha=0.6)
plt.xlabel("AIOE Score")
plt.ylabel("2023 Median Annual Wage")
plt.title("AI Exposure Score vs 2023 Median Annual Wage")
plt.show()

plt.figure(figsize=(8, 5))
plt.scatter(eda_df["aioe_score"], eda_df["log_tot_emp"], alpha=0.6)
plt.xlabel("AIOE Score")
plt.ylabel("Log10 Total Employment")
plt.title("AI Exposure Score vs 2023 Employment Size")
plt.show()

corr_table = eda_df[["aioe_score", "A_MEDIAN", "log_tot_emp"]].corr()
display(corr_table)





















